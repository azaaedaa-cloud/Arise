{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "url" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "orders": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product (Book)",
      "description": "Represents a book in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "coverImage": { "type": "string", "format": "url" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "stock": { "type": "integer" },
        "isDigital": { "type": "boolean" },
        "pdfUrl": { "type": "string", "format": "url" },
        "tier": { "type": "string", "enum": ["poverty", "growth", "wealth", "power"] }
      },
      "required": ["title", "author", "price", "category", "tier"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "bookId": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "paymentIntentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a book.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookId", "userId", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Book catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/books/{bookId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Book reviews"
    }
  }
}
