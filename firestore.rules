rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
         (request.auth.token.email == "azaaedaa@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAdmin() {
      return isAuthenticated() && 
        (isSuperAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (permission == 'manageProducts' && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.manageProducts == true))) ||
        (permission == 'manageOrders' && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'support' || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.manageOrders == true))) ||
        (permission == 'manageUsers' && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.manageUsers == true)) ||
        (permission == 'viewAnalytics' && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.viewAnalytics == true)))
      );
    }

    function isValidUser(data) {
      let isSpecialEmail = request.auth.token.email == "azaaedaa@gmail.com";
      let allowedRoles = ['super_admin', 'admin', 'editor', 'support', 'user'];
      let allowedRole = isSpecialEmail ? data.role in allowedRoles : data.role == 'user';
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             allowedRole;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'author', 'price', 'category', 'tier']) &&
             data.title is string && data.title.size() < 200 &&
             data.author is string && data.author.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.tier in ['poverty', 'growth', 'wealth', 'power'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.userId is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['pending', 'paid', 'shipped', 'delivered', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || hasPermission('manageUsers');
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isSuperAdmin() || hasPermission('manageUsers');
      allow delete: if isSuperAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow create, update: if hasPermission('manageProducts') && isValidProduct(request.resource.data);
      allow delete: if hasPermission('manageProducts');
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasPermission('manageOrders'));
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if hasPermission('manageOrders');
      allow delete: if isSuperAdmin();
    }
  }
}
